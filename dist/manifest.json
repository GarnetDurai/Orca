{
    "manifest_version": 3,
    "name": "Orca",
    "version": "1.0",
    "description": "LeetCode Analyzer and Smart Revision Scheduler",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "src/popup/index.html",
        "default_title": "Orca: Daily Revisions"
    },
    "options_ui": {
        "page": "src/options/index.html",
        "open_in_tab": true
    },
    "content_scripts": [
        {
            "matches": [
                "*://leetcode.com/problems/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}